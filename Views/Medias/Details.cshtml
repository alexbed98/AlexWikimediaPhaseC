@model Models.Media
@{
    ViewBag.PageTitle = "Détails";
    string search = Session["Search"] != null ? ((bool)Session["Search"]).ToString() : false.ToString();
    string SearchString = Session["SearchString"] != null ? (string)Session["SearchString"] : "";
    int currentMediaId = Session["CurrentMediaId"] != null ? (int)Session["CurrentMediaId"] : 0;
}

<div id="detailsPanel" class="detailsPanel">
    <!-- auto refreshed -->
</div>

@section Scripts {
    <script>
        let mediasLikesAutoRefreshPanel = null;

        $(() => {
            newSession(600);
            //setCurrentPageLimit()
            mediaDetails_ARP =
                new AutoRefreshedPanel("detailsPanel", "/Medias/GetMediaDetails", 5, mediaDetailsPostRefresh);
            mediasLikesAutoRefreshPanel =
                new AutoRefreshedPanel("mediaLikesPanel", "/Medias/GetMediaLikes?mediaId=@currentMediaId", 10, mediaLikesPostRefresh);
            sessionStorage.setItem("RestoreScrollPosition", "1");
        })

        function mediaLikesPostRefresh() {
            $(".toggleLikeCmd").off();
            $(".toggleLikeCmd").click(function (e) {
                let mediaId = $(this).attr("mediaId");

                mediasLikesAutoRefreshPanel.command("/Medias/ToggleLike?mediaId=" + mediaId);

                e.preventDefault();
            });
        }

        function mediaDetailsPostRefresh() {
            $(".toggleLikeCmd").off();
            $(".toggleLikeCmd").click(function (e) {
                let mediaId = $(this).attr("mediaId");

                mediasLikesAutoRefreshPanel.command("/Medias/GetMediaLikes?mediaId=" + mediaId);

                e.preventDefault();
            });

            highlightKeyword();
        }

        function highlightKeyword() {
            if ("@search" == "True") {
                let keyword = "@SearchString";
                if (keyword.length > 0) {
                     let titles = document.getElementsByClassName('mediaTitle');
                     Array.from(titles).forEach(title => {
                         highlight(keyword, title);
                     });
                     let descriptions = document.getElementsByClassName('mediaDescription');
                     Array.from(descriptions).forEach(description => {
                         highlight(keyword, description);
                     })
                }
            }
        }

    </script>
}