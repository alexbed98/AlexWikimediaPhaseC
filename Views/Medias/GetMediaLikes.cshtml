@model Models.Media

<div style="display: flex; justify-content: flex-end; gap: 5px; align-items: center; padding-right: 4px; cursor: pointer; ">
    <span style="color: rgb(0, 87, 204)" title="Usagers qui ont aimé : &#10;@string.Join("\n", Model.UserNames)">@Model.LikesCount</span>
    <i class="cmdIcon @(Model.LikedByCurrentUser ? "fa" : "fa-regular") fa-thumbs-up toggleLikeCmd" margin-left: 2px"
       mediaId="@Model.Id"></i>
</div>